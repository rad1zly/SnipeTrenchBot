# =============================================================================
# SnipeTrenchBot — Environment Configuration
# =============================================================================
# Copy .env.example to .env and fill in the required values.
# NEVER commit your .env file. It is in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# SAFETY (READ THIS FIRST)
# -----------------------------------------------------------------------------
# DRY_RUN=true  → bot logs all actions but does NOT sign/submit transactions.
#                 Use this for testing. No real SOL is at risk.
# DRY_RUN=false → bot executes REAL swaps with real SOL.
#                 Only flip this once you have tested in DRY_RUN.
DRY_RUN=false

# Hard cap on SOL spent per individual buy. Even in LIVE mode, the bot will
# never spend more than this on a single trade.
MAX_SOL_PER_TRADE=0.001

# Slippage tolerance in basis points. 500 = 5%. Pump.fun tokens are volatile
# — going too low will cause transactions to fail.
SLIPPAGE_BPS=500

# How long to hold the token after buying, in milliseconds.
# 1000 = 1 second (the documented default for this bot).
HOLD_MS=1000

# Daily loss cap in SOL. If realized + unrealized losses exceed this, the bot
# will pause itself for the rest of the UTC day.
DAILY_LOSS_CAP_SOL=0.05

# -----------------------------------------------------------------------------
# TELEGRAM
# -----------------------------------------------------------------------------
# 1. Talk to @BotFather on Telegram.
# 2. /newbot → follow prompts → copy the token here.
TELEGRAM_BOT_TOKEN=8914546620:AAETE0bT162RrLihoDVzAc27NZ5Eoico9fk

# 3. Open Telegram, send /start to your bot.
# 4. The bot will auto-add you to the subscriber list (multi-user mode).
#    Anyone who /start's will receive broadcast notifications. No need
#    to set TELEGRAM_CHAT_ID — that field is unused in multi-user mode.
#
# Legacy single-user setups may still leave TELEGRAM_CHAT_ID set. The bot
# will print a one-line warning at startup and continue normally.
#TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# SOLANA RPC
# -----------------------------------------------------------------------------
# Public RPC works but is rate-limited. Use Helius or another private RPC for
# production. Format: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=2e711e28-7218-4273-8cee-27064e053dc0

# Helius Enhanced Transactions API key. Required for wallet monitoring.
# Get one at https://helius.dev (free tier = 100k credits/month).
HELIUS_API_KEY=2e711e28-7218-4273-8cee-27064e053dc0

# -----------------------------------------------------------------------------
# BOT TRADING WALLET
# -----------------------------------------------------------------------------
# The wallet the bot uses to sign buy/sell transactions is NO LONGER stored
# in .env as of v0.3.0. Instead, set it via Telegram:
#
#   1. Open Telegram, send /start to this bot
#   2. Tap 🔑 Wallet
#   3. Tap ➕ Set Wallet
#   4. Send your private key (Base58 or JSON array)
#   5. The bot will encrypt it (AES-256-GCM) and auto-delete your message
#
# The encrypted key lives in the SQLite database (table `wallet`, single row).
# Only the public address + last 4 chars are ever shown or logged.
#
# To remove the wallet: tap 🗑 Remove Wallet in the 🔑 Wallet menu.
#
# Generate a new wallet with:  solana-keygen new --no-bip39-passphrase
# Or:                         npm run generate-wallet
# ⚠️  FUND THIS WALLET WITH ONLY WHAT YOU CAN AFFORD TO LOSE.

# -----------------------------------------------------------------------------
# WALLET ENCRYPTION PEPPER (optional)
# -----------------------------------------------------------------------------
# Combined with the host's machine-id to derive the AES-256-GCM key that
# encrypts your trading wallet at rest.
#
#   - Empty:  the wallet is bound to the machine-id. The DB is useless on
#             any other host. Safer for single-machine deployments.
#   - Set:    the wallet is portable. As long as you have this pepper AND
#             the DB file, you can decrypt on any machine. Safer for moving
#             the bot to a new VPS.
#
# Generate a strong pepper (one-time, save it somewhere safe):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# The pepper can be B64-encoded (prefix `B64:`) to avoid leaking in chat:
#   WALLET_PEPPER=B64:<base64-of-the-hex-or-random-bytes>
#
# Treat this value like any other secret. If you lose it AND lose the host
# the bot was running on, the encrypted wallet is unrecoverable.
#WALLET_PEPPER=

# -----------------------------------------------------------------------------
# JUPITER (Metis)
# -----------------------------------------------------------------------------
# Base URL for the Jupiter Swap API.
# Options:
#   https://quote-api.jup.ag/v6   — Jupiter v6 public aggregator
#   https://api.jup.ag/swap/v1    — Jupiter Swap API v1 (newer, host-aware)
#   https://metis.jup.io          — Jupiter Metis (MEV-protected routing)
JUPITER_API_URL=https://api.jup.ag/swap/v1

# Optional API key for higher rate limits on api.jup.ag. Not required for v6.
JUPITER_API_KEY=

# Priority fee in microlamports per compute unit. 0 = no priority fee.
# Bump this if you want faster landing (costs more SOL).
PRIORITY_FEE_MICROLAMPORTS=0

# -----------------------------------------------------------------------------
# MONITORING
# -----------------------------------------------------------------------------
# How often to poll Helius for new transactions on each watched wallet (ms).
# Lower = more responsive, more API credits consumed.
POLL_INTERVAL_MS=5000

# How many recent transactions to fetch per wallet per poll.
HELIUS_TX_LIMIT=10

# Optional: only act on tokens created after the bot started. Set to false to
# backfill detection on already-running positions. Default true.
ONLY_NEW_TOKENS=true

# PumpPortal Trading API (v0.9.0 migration — added 2026-06-19)
# Linked wallet public key: PTwz8oNUSphe34kH3oZgXSQ99Cj1UtpQeSpmQEZJenS
# Fund this wallet with >0.02 SOL for trade fee settlement + subscription.

# PumpPortal Trading API (v0.9.0 — added 2026-06-19)
# Linked wallet: PTwz8oNUSphe34kH3oZgXSQ99Cj1UtpQeSpmQEZJenS
PUMPPORTAL_API_KEY=6rw5jrkgb9qn8t2971vprp2be9u4pxbha5a3jg9jat3kerbcch94gg9rf974mt1ha112yn1td1k4mt2p9dd32naf5dq6uxjqad0mwu1m71544j9genvq4cja99hqgxuuc8r6ugagewyku9thqet3p8wt5anam6d53gwb8cr71n4pkv8b0t54x299gv4cgj3ed95jwb4cd0kuf8

# -----------------------------------------------------------------------------
# v0.8.8 (experimental) M4.0: Multi-lane tip routing with fallback.
# -----------------------------------------------------------------------------
# When the primary lane is congested, the same signed tx is re-submitted
# to the next lane. 4 lanes supported: jito, helius, 0slot, astralane.
#
#   jito      = Jito block engine (default primary)
#   helius    = Helius Sender (dual validator + Jito routing)
#   0slot     = 0slot regional endpoint (no API key — tip is the access)
#   astralane = Astralane Iris (requires ASTRALANE_API_KEY below)
#
# Per-lane timeout before falling back to the next lane.
TIP_LANE_PRIMARY=jito
TIP_LANE_FALLBACKS=helius,0slot,astralane
TIP_LANE_TIMEOUT_MS=8000

# Astralane Iris requires an API key. Get one at https://astralane.io.
# Without this key the astralane lane is skipped automatically.
ASTRALANE_API_KEY=

# 0slot API key. Get one at https://0slot.trade (sign up, then check
# dashboard). Without this key the 0slot lane is skipped automatically.
# 0slot recommends HTTP (faster than HTTPS) and a regional endpoint:
#   ny   = ny.0slot.trade (default, NY)
#   de   = de.0slot.trade (Frankfurt)
#   ams  = ams.0slot.trade (Amsterdam)
#   jp   = jp.0slot.trade (Tokyo)
#   la   = la.0slot.trade (Los Angeles)
ZERO_SLOT_API_KEY=
